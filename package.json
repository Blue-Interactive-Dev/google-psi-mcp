{
  "name": "google-psi-mcp",
  "version": "1.0.0",
  "description": "Google PageSpeed Insights MCP server for Railway",
  "main": "dist/server.js",
  "scripts": {
    "build": "rm -rf dist && esbuild src/server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js",
